msgstr "地平線遮蔽オーバーレイ設定"

msgid "Show overlay"
msgstr "オーバーレイを表示"

msgid "Show filled obstruction area"
msgstr "遮蔽塗りつぶし領域を表示"

msgid "Show outline"
msgstr "輪郭線を表示"

msgid "Fill opacity: %1%"
msgstr "塗りつぶし不透明度: %1%"

msgid "Line opacity: %1%"
msgstr "線の不透明度: %1%"

msgid "Fill color"
msgstr "塗りつぶし色"

msgid "Line color"
msgstr "線の色"

msgid "Choose file..."
msgstr "ファイルを選択..."

msgid "Reload table"
msgstr "遮蔽表を再読み込み"

msgid "Obstruction table:"
