#: src/gui/HorizonOverlayDialog.cpp:232
msgid ""
"Draw a profile directly in the sky: hold Shift and drag with the left mouse "
"button to add points; hold Shift and drag with the right mouse button to "
"erase nearby points."
msgstr "空に直接プロファイルを描画します。Shift を押しながら左ボタンでドラッグして点を追加し、Shift を押しながら右ボタンでドラッグして近くの点を消去します。"

#: src/gui/HorizonOverlayDialog.cpp:233
msgid "Start drawing profile"
msgstr "プロファイル描画を開始"

#: src/gui/HorizonOverlayDialog.cpp:234
msgid "Finish and save drawing"
msgstr "描画を終了して保存"

#: src/gui/HorizonOverlayDialog.cpp:235
msgid "Appearance"
msgstr "外観"

#: src/gui/HorizonOverlayDialog.cpp:236
msgid "Fill opacity:"
msgstr "塗りつぶしの不透明度:"

#: src/gui/HorizonOverlayDialog.cpp:237
msgid "Line opacity:"
msgstr "線の不透明度:"

#: src/gui/HorizonOverlayDialog.cpp:238
msgid "Line width:"
msgstr "線幅:"

#: src/gui/HorizonOverlayDialog.cpp:241
msgid "Save settings"
msgstr "設定を保存"

