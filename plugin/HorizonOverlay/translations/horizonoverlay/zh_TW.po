msgid "Obstruction profile"
msgstr "遮擋輪廓"

#: src/gui/HorizonOverlayDialog.cpp:221
msgid "Obstruction table:"
msgstr "遮擋表："

#: src/gui/HorizonOverlayDialog.cpp:222
msgid "Choose file..."
msgstr "選擇檔案..."

#: src/gui/HorizonOverlayDialog.cpp:223
msgid "Reload table"
msgstr "重新載入遮擋表"

#: src/gui/HorizonOverlayDialog.cpp:224
msgid "Clear points"
msgstr "清除點"

#: src/gui/HorizonOverlayDialog.cpp:225
msgid "Save table"
msgstr "儲存遮擋表"

#: src/gui/HorizonOverlayDialog.cpp:226
msgid "Overlay controls"
msgstr "疊加層控制"

#: src/gui/HorizonOverlayDialog.cpp:227
msgid "Show overlay"
msgstr "顯示疊加層"

#: src/gui/HorizonOverlayDialog.cpp:228
msgid "Show filled obstruction area"
msgstr "顯示遮擋填充區域"

#: src/gui/HorizonOverlayDialog.cpp:229
