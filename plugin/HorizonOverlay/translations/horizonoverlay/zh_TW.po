msgstr "在 Stellarium 原有地景上方繪製透明的本地遮擋地平線疊加層。"

msgid "Horizon Overlay Settings"
msgstr "地平線遮擋疊加設定"

msgid "Show overlay"
msgstr "顯示疊加層"

msgid "Show filled obstruction area"
msgstr "顯示遮擋填充區域"

msgid "Show outline"
msgstr "顯示輪廓線"

msgid "Fill opacity: %1%"
msgstr "填充透明度：%1%"

msgid "Line opacity: %1%"
msgstr "線條透明度：%1%"

msgid "Fill color"
msgstr "填充顏色"

msgid "Line color"
msgstr "線條顏色"

msgid "Choose file..."
msgstr "選擇檔案..."

msgid "Reload table"
msgstr "重新載入遮擋表"

msgid "Obstruction table:"
msgstr "遮擋表："

msgid "Close"
msgstr "關閉"

msgid "Choose obstruction table"
msgstr "選擇遮擋表"

