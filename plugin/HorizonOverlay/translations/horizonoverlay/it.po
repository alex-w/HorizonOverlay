msgstr "Scegli tabella ostacoli"

#: src/gui/HorizonOverlayDialog.cpp:186
msgid "Text files (*.txt *.hrz *.csv);;All files (*)"
msgstr "File di testo (*.txt *.hrz *.csv);;Tutti i file (*)"

