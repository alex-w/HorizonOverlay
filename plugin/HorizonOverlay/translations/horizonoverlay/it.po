msgid "Table reloaded."
msgstr "Tabella ricaricata."

#: src/gui/HorizonOverlayDialog.cpp:202
msgid "Points cleared."
msgstr "Punti cancellati."

#: src/gui/HorizonOverlayDialog.cpp:206
msgid "Table saved."
msgstr "Tabella salvata."

#: src/gui/HorizonOverlayDialog.cpp:206
msgid "Could not save table."
msgstr "Impossibile salvare la tabella."

