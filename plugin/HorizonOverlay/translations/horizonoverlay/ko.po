msgid "Horizon Overlay"
msgstr "지평선 차폐 오버레이"

msgid "Draws a transparent local obstruction horizon overlay above the normal Stellarium landscape."
msgstr "일반 Stellarium 지형 위에 투명한 로컬 차폐 지평선 오버레이를 그립니다."

msgid "Horizon Overlay Settings"
msgstr "지평선 차폐 오버레이 설정"

msgid "Show overlay"
msgstr "오버레이 표시"

msgid "Show filled obstruction area"
msgstr "차폐 채움 영역 표시"

msgid "Show outline"
msgstr "윤곽선 표시"

msgid "Fill opacity: %1%"
msgstr "채움 불투명도: %1%"

msgid "Line opacity: %1%"
msgstr "선 불투명도: %1%"

msgid "Fill color"
msgstr "채움 색상"

msgid "Line color"
msgstr "선 색상"

msgid "Choose file..."
msgstr "파일 선택..."

msgid "Reload table"
