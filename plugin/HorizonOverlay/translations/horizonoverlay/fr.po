#: src/HorizonOverlay.cpp:380 src/HorizonOverlay.cpp:431
#: src/HorizonOverlay.cpp:432 src/gui/HorizonOverlayDialog.cpp:251
msgid "Horizon Overlay"
msgstr "Superposition d'horizon"

#: src/HorizonOverlay.cpp:383 src/gui/HorizonOverlayDialog.cpp:257
msgid ""
"Draws a transparent local obstruction horizon overlay above the normal "
"Stellarium landscape."
msgstr ""
"Dessine une superposition transparente des obstacles locaux de l'horizon au-"
"dessus du paysage Stellarium normal."

#: src/HorizonOverlay.cpp:431
msgid "Show local obstruction horizon overlay"
msgstr "Afficher la superposition des obstacles locaux de l'horizon"

#: src/HorizonOverlay.cpp:432
msgid "Show settings dialog"
msgstr "Afficher la boîte de dialogue des paramètres"

#: src/HorizonOverlay.cpp:649
#, qt-format
msgid ""
"Performance: %1 ms last, %2 ms avg, %3 ms max | FoV %4 deg | %5 | %6 samples"
msgstr ""
"Performance : %1 ms dernier, %2 ms moy., %3 ms max. | champ %4 deg | %5 | %6 "
"échantillons"

#: src/gui/HorizonOverlayDialog.cpp:102
msgid ""
"Edit mode is active. Hold Shift and drag with the left mouse button to add "
"points; hold Shift and drag with the right mouse button to erase nearby "
"points."
msgstr "Le mode édition est actif. Maintenez Maj et faites glisser avec le bouton gauche pour ajouter des points ; maintenez Maj et faites glisser avec le bouton droit pour effacer les points proches."

#: src/gui/HorizonOverlayDialog.cpp:116
msgid ""
"Drawing mode is active. Hold Shift and drag with the left mouse button in "
"the sky to add points; hold Shift and drag with the right mouse button to "
"erase nearby points."
msgstr "Le mode dessin est actif. Maintenez Maj et faites glisser avec le bouton gauche dans le ciel pour ajouter des points ; maintenez Maj et faites glisser avec le bouton droit pour effacer les points proches."

#: src/gui/HorizonOverlayDialog.cpp:126
msgid "Drawing finished and table saved."
msgstr "Dessin terminé et table enregistrée."

#: src/gui/HorizonOverlayDialog.cpp:126
msgid "Drawing finished, but the table could not be saved."
msgstr "Dessin terminé, mais la table n'a pas pu être enregistrée."

#: src/gui/HorizonOverlayDialog.cpp:156 src/gui/HorizonOverlayDialog.cpp:239
msgid "Fill color"
msgstr "Couleur de remplissage"

#: src/gui/HorizonOverlayDialog.cpp:164 src/gui/HorizonOverlayDialog.cpp:240
msgid "Line color"
msgstr "Couleur de ligne"

#: src/gui/HorizonOverlayDialog.cpp:184
msgid "Choose obstruction table"
msgstr "Choisir la table d'obstacles"

#: src/gui/HorizonOverlayDialog.cpp:186
msgid "Text files (*.txt *.hrz *.csv);;All files (*)"
msgstr "Fichiers texte (*.txt *.hrz *.csv);;Tous les fichiers (*)"

