msgstr "Superposition d'horizon"

msgid "Draws a transparent local obstruction horizon overlay above the normal Stellarium landscape."
msgstr "Dessine une superposition transparente des obstacles locaux de l'horizon au-dessus du paysage Stellarium normal."

msgid "Horizon Overlay Settings"
msgstr "Paramètres de la superposition d'horizon"

msgid "Show overlay"
msgstr "Afficher la superposition"

msgid "Show filled obstruction area"
msgstr "Afficher la zone d'obstruction remplie"

msgid "Show outline"
msgstr "Afficher le contour"

msgid "Fill opacity: %1%"
msgstr "Opacité du remplissage : %1%"

msgid "Line opacity: %1%"
msgstr "Opacité de la ligne : %1%"

msgid "Fill color"
msgstr "Couleur de remplissage"

msgid "Line color"
msgstr "Couleur de ligne"

msgid "Choose file..."
msgstr "Choisir un fichier..."

msgid "Reload table"
msgstr "Recharger la table"

msgid "Obstruction table:"
msgstr "Table des obstructions :"

msgid "Close"
msgstr "Fermer"

msgid "Choose obstruction table"
msgstr "Choisir la table des obstructions"

msgid "Text files (*.txt *.hrz *.csv);;All files (*)"
msgstr "Fichiers texte (*.txt *.hrz *.csv);;Tous les fichiers (*)"
