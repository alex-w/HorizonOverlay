#: src/gui/HorizonOverlayDialog.cpp:232
msgid ""
"Draw a profile directly in the sky: hold Shift and drag with the left mouse "
"button to add points; hold Shift and drag with the right mouse button to "
"erase nearby points."
msgstr "Dessinez un profil directement dans le ciel : maintenez Maj et faites glisser avec le bouton gauche pour ajouter des points ; maintenez Maj et faites glisser avec le bouton droit pour effacer les points proches."

#: src/gui/HorizonOverlayDialog.cpp:233
msgid "Start drawing profile"
msgstr "Commencer le dessin du profil"

#: src/gui/HorizonOverlayDialog.cpp:234
msgid "Finish and save drawing"
msgstr "Terminer et enregistrer le dessin"

#: src/gui/HorizonOverlayDialog.cpp:235
msgid "Appearance"
msgstr "Apparence"

#: src/gui/HorizonOverlayDialog.cpp:236
msgid "Fill opacity:"
msgstr "Opacité du remplissage :"

#: src/gui/HorizonOverlayDialog.cpp:237
msgid "Line opacity:"
msgstr "Opacité de la ligne :"

#: src/gui/HorizonOverlayDialog.cpp:238
msgid "Line width:"
msgstr "Largeur de ligne :"

